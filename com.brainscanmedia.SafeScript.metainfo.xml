<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.brainscanmedia.SafeScript</id>
  <name>SafeScript</name>
  <summary>Organize and manage code snippets</summary>
  <branding>
   <color type="primary" scheme_preference="light">#4a90d9</color>
   <color type="primary" scheme_preference="dark">#1a3a5c</color>
  </branding>
  <description>
    <p>SafeScript is a fast, clean code snippet manager for developers. Organize your snippets into folders, search instantly, and edit with a built-in syntax-aware code editor.</p>
    <ul>
      <li>Organize snippets into folders with drag-to-reorder</li>
      <li>Syntax-aware code editor with line numbers</li>
      <li>Dark and light mode</li>
      <li>Instant search across all snippets</li>
      <li>Notes field for each snippet</li>
      <li>100% local storage — all data stays on your device</li>
    </ul>
  </description>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <developer id="com.brainscanmedia">
    <name>BrainScanMedia.com, Inc.</name>
  </developer>
  <url type="homepage">https://www.brainscanmedia.com</url>
  <url type="vcs-browser">https://github.com/BrainScanMedia/SafeScript</url>
  <url type="bugtracker">https://github.com/BrainScanMedia/SafeScript/issues</url>
  <launchable type="desktop-id">com.brainscanmedia.SafeScript.desktop</launchable>
  <screenshots>
